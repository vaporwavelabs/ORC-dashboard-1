# ANYTHING_LLM_API_KEY: API Key for your AnythingLLM instance.
ANYTHING_LLM_API_KEY=
# ANYTHING_LLM_BASE_URL: The base URL of your AnythingLLM instance (e.g., http://localhost:3001).
ANYTHING_LLM_BASE_URL=
# ANYTHING_LLM_WORKSPACE_SLUG: The slug of the workspace you want to chat with.
ANYTHING_LLM_WORKSPACE_SLUG=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
